#!/usr/bin/env bash
# Local pre-commit hook mirroring .github/workflows/ci.yml.
# Activate once: git config core.hooksPath .githooks
#
# Bypass for emergency commits: git commit --no-verify

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

red()    { printf '\033[31m%s\033[0m\n' "$*"; }
green()  { printf '\033[32m%s\033[0m\n' "$*"; }
yellow() { printf '\033[33m%s\033[0m\n' "$*"; }

step() { printf '\n→ %s\n' "$1"; }

# 1. gofmt (catches formatting drift fastest)
step "gofmt"
fmt_issues=$(gofmt -l ./src/ 2>&1)
if [ -n "$fmt_issues" ]; then
	red "gofmt issues:"
	echo "$fmt_issues"
	red "fix: gofmt -w ./src/"
	exit 1
fi

# 2. go vet
step "go vet"
go vet ./src/...

# 3. go build
step "go build"
go build ./src/...

# 4. go test -race (matches CI's test step)
step "go test -race"
go test -race ./src/...

# 5. golangci-lint (matches CI's golangci-lint-action)
step "golangci-lint"
if command -v golangci-lint >/dev/null 2>&1; then
	golangci-lint run ./src/...
else
	yellow "skipped: golangci-lint not on PATH"
	yellow "install:  go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.10.1"
fi

# 6. govulncheck (matches CI's govulncheck-action)
step "govulncheck"
if command -v govulncheck >/dev/null 2>&1; then
	govulncheck ./src/...
else
	yellow "skipped: govulncheck not on PATH"
	yellow "install:  go install golang.org/x/vuln/cmd/govulncheck@latest"
fi

green "all checks passed"
